<table cellpadding="0" cellspacing="0" border="0" style="font-family: Roboto, Arial, sans-serif; font-size: 11pt; color: #595959;">
  <tr>
    <!-- Logo -->
    <td style="padding-right: 16px; vertical-align: middle; text-align: center;">
      <img src="data:image/png;base64,"
           width="100" height="101"
           alt="{{ user.companyName }}"
           style="display: block;">
    </td>

    <!-- Vertikaler Balken -->
    <td style="border-left: 2px solid #595959; padding: 0 16px 0 0;">&nbsp;</td>

    <!-- Kontaktdaten -->
    <td style="vertical-align: top; padding-left: 12px;">
      <p style="margin: 0 0 4px 0;">
        <strong style="color: #595959;">{{ user.displayName }} – {{ user.companyName }}</strong>
      </p>
      <p style="margin: 0;">
        Phone:&nbsp;&nbsp;&nbsp;
        <a href="tel:{{ user.phone }}" style="color: blue;">{{ user.phone }}</a>
      </p>
      <p style="margin: 0;">
        Mobile:&nbsp;&nbsp;
        <a href="tel:{{ user.mobilePhone }}" style="color: blue;">{{ user.mobilePhone }}</a>
      </p>
      <p style="margin: 0;">
        <a href="mailto:{{ user.mail }}" style="color: blue;">{{ user.mail }}</a>
      </p>
      <p style="margin: 0;">
        <a href="{{ user.website }}" style="color: blue;">{{ user.website }}</a>
      </p>
      <p style="margin: 4px 0 0 0; color: #595959;">Triebelsstr. 4, 52066 Aachen</p>
    </td>
  </tr>
</table>

<!-- Bookings -->
<table cellpadding="0" cellspacing="0" border="0" style="margin-top: 8px;">
  <tr>
    <td style="vertical-align: middle; padding-right: 6px;">
      <a href="{{ user.bookingsUrl }}" style="text-decoration: none;">
        <img src="https://res.cdn.office.net/assets/bookwithme/misc/CalendarPerson20px.png"
             width="20" height="20" border="0" alt="Kalender">
      </a>
    </td>
    <td style="vertical-align: middle;">
      <a href="{{ user.bookingsUrl }}"
         style="color: #0078D4; text-decoration: none; font-family: Aptos, Arial, sans-serif; font-size: 11pt;">
        Buchen Sie einen Termin, um mich zu treffen
      </a>
    </td>
  </tr>
</table>
